{
  "compilerOptions": {
    "target": "es2016",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    "next.config.js",
    "next.config.mjs",
    "next.config.cjs",
    "next.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
