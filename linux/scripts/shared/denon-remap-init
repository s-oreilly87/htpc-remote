#!/bin/bash

set -u  # don't crash the session on minor errors

CARD_NAME="alsa_card.pci-0000_00_1f.3"
MASTER_SINK="alsa_output.pci-0000_00_1f.3.hdmi-surround"
REMAP_SINK="denon51_remap"

# Give PipeWire / Pulse a moment to fully come up
sleep 5

# Make sure card is in HDMI 5.1 mode (best-effort)
if command -v pactl >/dev/null 2>&1; then
  pactl set-card-profile "$CARD_NAME" output:hdmi-surround >/dev/null 2>&1 || true
fi

# If the remap sink already exists, just make it default and exit
if pactl list short sinks | grep -q "$REMAP_SINK"; then
  pactl set-default-sink "$REMAP_SINK" >/dev/null 2>&1 || true
  exit 0
fi

# Otherwise, create it
pactl load-module module-remap-sink \
  sink_name="$REMAP_SINK" \
  master="$MASTER_SINK" \
  channels=6 \
  master_channel_map=front-left,front-right,rear-left,rear-right,front-center,lfe \
  channel_map=front-left,front-right,front-center,lfe,rear-left,rear-right \
  remix=yes >/dev/null 2>&1 || true

# Try to make it default
pactl set-default-sink "$REMAP_SINK" >/dev/null 2>&1 || true

exit 0
