#!/usr/bin/env bash
set -euo pipefail

app="${1:-}"

case "$app" in
  kodi)
    nohup kodi >/dev/null 2>&1 &
    ;;
  plexamp)
    nohup "$HOME/bin/plexamp-wine" >/dev/null 2>&1 &
    ;;
  moonlight)
    nohup flatpak run com.moonlight_stream.Moonlight >/dev/null 2>&1 &
    ;;
  qobuz)
    nohup "$HOME/bin/qobuz-wine" >/dev/null 2>&1 &
    ;;
  *)
    echo "Usage: htpc-launch {kodi|plexamp|moonlight|qobuz}"
    exit 1
    ;;
esac
