#!/usr/bin/env bash
set -euo pipefail

what="${1:-}"

CARD="alsa_card.pci-0000_00_1f.3"
STEREO_SINK="alsa_output.pci-0000_00_1f.3.hdmi-stereo"
REMAPPED_SINK="denon51_remap"

move_first_matching_sink_input() {
  local pattern="$1"
  local dest_sink="$2"
  # Find first sink-input whose block matches pattern (case-insensitive)
  local id
  id="$(pactl list sink-inputs | awk -v IGNORECASE=1 -v pat="$pattern" '
    BEGIN{RS="Sink Input #"; FS="\n"}
    NR>1{
      block=$0
      if (block ~ pat) { gsub(/^[ \t\r\n]+|[ \t\r\n]+$/, "", $1); print $1; exit }
    }')"
  if [[ -n "${id:-}" ]]; then
    pactl move-sink-input "$id" "$dest_sink" >/dev/null 2>&1 || true
  fi
}

case "$what" in
  qobuz)
    pactl set-card-profile "$CARD" output:hdmi-stereo
    # If Qobuz is already playing, try to move it. (Pattern may need tuning.)
    move_first_matching_sink_input "qobuz|Qobuz" "$STEREO_SINK"
    nohup "$HOME/bin/qobuz-wine" >/dev/null 2>&1 &
    ;;
  plexamp)
    pactl set-card-profile "$CARD" output:hdmi-surround
    # Ensure Plexamp starts only when remap exists (your guarded script does this)
    nohup "$HOME/bin/plexamp-wine" >/dev/null 2>&1 &
    # If Plexamp already has a stream, try to move it (pattern may need tuning)
    move_first_matching_sink_input "plexamp|Plexamp" "$REMAPPED_SINK"
    ;;
  *)
    echo "Usage: htpc-listen {qobuz|plexamp}" >&2
    exit 1
    ;;
esac
