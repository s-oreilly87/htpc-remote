# ─── Host (the machine running Next.js) ──────────────────────────────────────
# IP of the machine running the Next.js server.
# Used for the QR code URL and Caddy reverse proxy config.
NEXT_PUBLIC_HOST_IP=192.168.1.xxx

# ─── HTPC ─────────────────────────────────────────────────────────────────────
# OS/platform of the HTPC being controlled (not necessarily the Next.js host)
# OS/platform of the HTPC being controlled (not the Next.js host).
# Options: PC | LINUX_WAYLAND | LINUX_X11 | MACOS
# PC and LINUX_WAYLAND: full control — presets, app launch, display/audio modes.
# LINUX_X11 and MACOS: keystroke/mouse only — script-dependent controls hidden.
NEXT_PUBLIC_HTPC_PLATFORM=LINUX_WAYLAND

# IP of the HTPC being controlled. Always set this to the HTPC's LAN IP.
# When HTPC_IP matches HOST_IP, commands run locally. When they differ,
# commands are proxied to linux/htpc-agent running on the HTPC.
NEXT_PUBLIC_HTPC_IP=192.168.1.xxx

# Port the linux/htpc-agent listens on. Must be NEXT_PUBLIC so the AirMouse
# client can construct the direct socket.io URL.
# Only needed when NEXT_PUBLIC_HTPC_IP is a remote address.
NEXT_PUBLIC_LINUX_HTPC_AGENT_PORT=3001

# ─── Devices ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DENON_IP=192.168.1.252
NEXT_PUBLIC_ROKU_IP=192.168.1.222

# Windows PC running EventGhost for GameStream control
NEXT_PUBLIC_GAMESTREAM_IP=192.168.1.254

# ─── Setup examples ───────────────────────────────────────────────────────────
#
# 1. Linux HTPC is the host (production)
#    Next.js runs on the HTPC. No agent needed.
#
#    NEXT_PUBLIC_HOST_IP=192.168.1.245        # HTPC IP (same machine)
#    NEXT_PUBLIC_HTPC_PLATFORM=LINUX_WAYLAND
#    NEXT_PUBLIC_HTPC_IP=192.168.1.245
#    NEXT_PUBLIC_DENON_IP=192.168.1.252
#    NEXT_PUBLIC_ROKU_IP=192.168.1.222
#    NEXT_PUBLIC_GAMESTREAM_IP=192.168.1.254

#
# 2. Mac as host, Linux HTPC remote (development)
#    Next.js runs on the Mac. linux/htpc-agent must be running on the HTPC.
#
#    NEXT_PUBLIC_HOST_IP=192.168.1.231         # Mac IP
#    NEXT_PUBLIC_HTPC_PLATFORM=LINUX_WAYLAND
#    NEXT_PUBLIC_HTPC_IP=192.168.1.245       # HTPC IP — enables agent routing
#    NEXT_PUBLIC_LINUX_HTPC_AGENT_PORT=3001
#    NEXT_PUBLIC_DENON_IP=192.168.1.252
#    NEXT_PUBLIC_ROKU_IP=192.168.1.222
#    NEXT_PUBLIC_GAMESTREAM_IP=192.168.1.254

#
# 3. Windows HTPC is the host
#    Next.js runs on the HTPC. EventGhost handles keystrokes.
#
#    NEXT_PUBLIC_HOST_IP=192.168.1.245        # HTPC IP (same machine)
#    NEXT_PUBLIC_HTPC_PLATFORM=PC
#    NEXT_PUBLIC_HTPC_IP=192.168.1.245       # same — used for EventGhost URL
#    NEXT_PUBLIC_DENON_IP=192.168.1.252
#    NEXT_PUBLIC_ROKU_IP=192.168.1.222
#    NEXT_PUBLIC_GAMESTREAM_IP=192.168.1.254
