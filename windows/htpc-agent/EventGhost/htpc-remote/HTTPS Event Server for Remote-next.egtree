            <Event Name="Keyboard.Shift+Ctrl+W" XML_Guid="{4E7822E2-3627-40B2-A44C-D0AE199D89B5}" />
            <Action XML_Guid="{3055CB1F-A3CC-4888-8F92-F3952B4BA368}">
