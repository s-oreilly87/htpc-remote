    <Folder Name="Monitor Control" XML_Guid="{6A8D3866-D5B8-4CAF-828E-4223EF42A8B3}" Expanded="True">
        <Macro Name="Turn On PC Monitor" id="61" XML_Guid="{7B4E92C0-6391-4A1A-9901-CC51AFA1B80E}" Expanded="True">
            <Event Name="System.UnIdle" XML_Guid="{7FC5420E-95C6-4A34-9B05-0EB518AFF6C0}" />
            <Action Name="Spam Monitor On" XML_Guid="{133BCB62-8822-4F58-985E-0061F7DAE6FA}">
                EventGhost.PythonScript(u'\ndef main():\n    for i in range(15):\n        eg.plugins.System.Execute(u\'C:\\\\Program Files (x86)\\\\EventGhost\\\\htpc-remote\\\\utilities\\\\ControlMyMonitor.exe\', u\'/SetValueIfNeeded "Acer XFA240" D6 1\', 3, False, 5, u\'\', False, False, u\'\', False, True, False, False)\nmain()')
            </Action>
            <Action XML_Guid="{1C74AFF9-7B85-4F86-BE2A-85227FB12B9D}">
                Window.SendKeys(u'{MediaPlayPause}', False, 2)
            </Action>
            <Action XML_Guid="{7A134416-E199-4605-B7E3-778FEE5713A7}">
                EventGhost.Wait(1.0)
            </Action>
            <Action XML_Guid="{1C74AFF9-7B85-4F86-BE2A-85227FB12B9D}">
                Window.SendKeys(u'{MediaPlayPause}', False, 2)
            </Action>
            <Action XML_Guid="{55944529-086E-4D12-972B-413F35C32949}">
                EventGhost.EnableItem(XmlIdLink(23))
            </Action>
        </Macro>
        <Macro Name="Turn Off PC Monitor" id="67" XML_Guid="{7B4E92C0-6391-4A1A-9901-CC51AFA1B80E}" Expanded="True">
            <Action Name="Spam Monitor Off" XML_Guid="{133BCB62-8822-4F58-985E-0061F7DAE6FA}">
                EventGhost.PythonScript(u'\ndef main():\n    for i in range(12):\n        eg.plugins.System.Execute(u\'C:\\\\Program Files (x86)\\\\EventGhost\\\\htpc-remote\\\\utilities\\\\ControlMyMonitor.exe\', u\'/SetValueIfNeeded "Acer XFA240" D6 4\', 3, False, 5, u\'\', False, False, u\'\', False, True, False, False)\nmain()')
            </Action>
            <Action XML_Guid="{BB24BAD5-8ED0-49E5-BF97-0ECC9E0D0516}">
                EventGhost.DisableItem(XmlIdLink(23))
            </Action>
        </Macro>
        <Macro Name="Turn Off PC Monitor if current input is PC" id="70" XML_Guid="{7B4E92C0-6391-4A1A-9901-CC51AFA1B80E}" Expanded="True">
            <Event Name="System.Idle" XML_Guid="{F16EB18D-4F57-4916-B55E-4E29ACC4BB60}" />
            <Action Name="Check: Is Monitor input = PC" XML_Guid="{33980256-C1D4-40BF-AF53-19960FC6DCCA}">
                EventGhost.PythonScript(u'def main():\n    monitor_input = eg.plugins.System.Execute(u\'C:\\\\Program Files (x86)\\\\EventGhost\\\\htpc-remote\\\\utilities\\\\ControlMyMonitor.exe\', u\'/GetValue "Acer XFA240" 60\', 0, True, 2, u\'\', False, False, u\'\', False, True, False, False)\n    if (monitor_input == 15):\n        eg.result = True\n    else:\n        eg.result = False\n\nmain()')
            </Action>
            <Action XML_Guid="{3AA52257-6808-418E-B7AF-737ADDEEF2E2}">
                EventGhost.NewJumpIf(XmlIdLink(67), 0, False)
            </Action>
        </Macro>
        <Macro Name="Toggle PC Monitor On/Off" id="74" XML_Guid="{7B4E92C0-6391-4A1A-9901-CC51AFA1B80E}" Expanded="True">
            <Action XML_Guid="{2944146E-8F42-4736-9BF0-20B8C31A6DC3}">
