        <Folder Name="App Shortcuts" XML_Guid="{D5035D24-3837-48A5-886E-74E4327F8CE0}">
            <Macro Name="Run Playnite" XML_Guid="{BB6186B2-EA8B-4ED5-AAF7-22CB3303CB57}">
                <Event Name="HTTP.launchPlaynite" XML_Guid="{1659E09C-4125-4C94-900A-2ED000BCAF3F}" />
                <Action XML_Guid="{C321D1D3-AF25-48C1-BDA9-BE5517B205B6}">
                    System.Execute(u'C:\\Users\\nuff_\\AppData\\Local\\Playnite\\Playnite.FullscreenApp.exe', u'', 0, False, 2, u'', False, False, u'', False, False, False, False)
                </Action>
                <Action XML_Guid="{C67BB2CC-0354-43B5-A5D5-677F5C748120}">
                    Window.BringToFront()
                </Action>
            </Macro>
            <Macro Name="Run Kodi" XML_Guid="{BB6186B2-EA8B-4ED5-AAF7-22CB3303CB57}" Expanded="True">
                <Event Name="HTTP.launchKodi" XML_Guid="{085F6863-9325-4A5B-AEEF-5B3A83F32191}" />
                <Action XML_Guid="{C321D1D3-AF25-48C1-BDA9-BE5517B205B6}">
                    System.Execute(u'C:\\Program Files\\Kodi\\kodi.exe', u'', 0, False, 2, u'', False, False, u'', False, False, False, False)
                </Action>
                <Action XML_Guid="{C67BB2CC-0354-43B5-A5D5-677F5C748120}">
