            <Action XML_Guid="{7A37C8E4-2C64-43FD-9FB0-6B814B5EB184}">
                EventGhost.JumpIfElse(XmlIdLink(70), 0, False, XmlIdLink(61), False)
            </Action>
        </Macro>
